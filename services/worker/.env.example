DATABASE_URL=postgresql://noteflow:noteflow@localhost:5432/noteflow
REDIS_URL=redis://localhost:6379/0
DOCUMENT_QUEUE=queue:document-analysis

# Whole-document task pool. PDF render/OCR/VLM pools are configured separately.
WORKER_MAX_CONCURRENT_TASKS=3
WORKER_MAX_BACKGROUND_TASKS=1
PDF_CPU_WORKERS=0
PDF_IO_WORKERS=0
PDF_GPU_WORKERS=0
PDF_GPU_MEMORY_PER_TASK_MIB=2048
PDF_GPU_MEMORY_RESERVE_MIB=1536
PDF_GPU_WORKER_CAP=4
PDF_OCR_BACKEND=auto
PDF_OCR_LANGUAGES=en
PDF_ENABLE_GPU_OCR=true
PDF_CLEANUP_INTERMEDIATE_FILES=true
PARSE_STALE_TASK_AFTER_MINUTES=10
PARSE_MAX_TASK_RETRIES=3

# auto/router rotates across providers and every comma/newline separated key.
VISION_PROVIDER=router
VISION_PROVIDER_ORDER=gemini,openai,mcp
VISION_CONCURRENT_REQUESTS=4
VISION_BATCH_SIZE=4
VISION_MAX_REGIONS_PER_DOCUMENT=96
VISION_LONG_DOCUMENT_MAX_REGIONS=64
VISION_FORMULA_RECOVERY_MAX_REGIONS=320
VISION_REQUEST_TIMEOUT_SECONDS=60
VISION_REQUEST_MAX_ATTEMPTS=3
VISION_RETRY_BACKOFF_SECONDS=2
VISION_RETRY_MAX_BACKOFF_SECONDS=30

GEMINI_API_KEYS=
GEMINI_VISION_MODEL=gemini-2.5-flash
OPENAI_API_KEYS=
OPENAI_VISION_MODEL=gpt-4o-mini

# MCP Streamable HTTP (stable 2025-11-25 handshake/session protocol).
MCP_VISION_ENDPOINT=
MCP_VISION_API_KEYS=
MCP_VISION_TOOL=analyze_pdf_region
MCP_PROTOCOL_VERSION=2025-11-25
