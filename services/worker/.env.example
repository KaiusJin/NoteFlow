DATABASE_URL=postgresql://noteflow:noteflow@localhost:5432/noteflow
REDIS_URL=redis://localhost:6379/0
DOCUMENT_QUEUE=queue:document-analysis

# Whole-document task pool. PDF render/OCR/VLM pools are configured separately.
WORKER_MAX_CONCURRENT_TASKS=3
WORKER_MAX_BACKGROUND_TASKS=1
PDF_CPU_WORKERS=0
PDF_IO_WORKERS=0
PDF_GPU_WORKERS=0
PDF_GPU_MEMORY_PER_TASK_MIB=2048
PDF_GPU_MEMORY_RESERVE_MIB=1536
PDF_GPU_WORKER_CAP=4
PDF_OCR_BACKEND=auto
PDF_OCR_LANGUAGES=en
PDF_ENABLE_GPU_OCR=true
PDF_CLEANUP_INTERMEDIATE_FILES=true
PARSE_STALE_TASK_AFTER_MINUTES=10
PARSE_MAX_TASK_RETRIES=3

# auto/router rotates across providers and every comma/newline separated key.
VISION_PROVIDER=router
VISION_PROVIDER_ORDER=gemini,openai,mcp
VISION_CONCURRENT_REQUESTS=4
VISION_MAX_REGIONS_PER_DOCUMENT=96
VISION_LONG_DOCUMENT_MAX_REGIONS=64
VISION_FORMULA_RECOVERY_MAX_REGIONS=320
VISION_REQUEST_TIMEOUT_SECONDS=60
VISION_REQUEST_MAX_ATTEMPTS=3
VISION_RETRY_BACKOFF_SECONDS=2
VISION_RETRY_MAX_BACKOFF_SECONDS=30

GEMINI_API_KEYS=
GEMINI_VISION_MODEL=gemini-2.5-flash
OPENAI_API_KEYS=
OPENAI_VISION_MODEL=gpt-4o-mini

# MCP Streamable HTTP (stable 2025-11-25 handshake/session protocol).
MCP_VISION_ENDPOINT=
MCP_VISION_API_KEYS=
MCP_VISION_TOOL=analyze_pdf_region
MCP_PROTOCOL_VERSION=2025-11-25

# Conversation memory: short-term window (token budgets, not message counts).
MEMORY_WINDOW_MAX_TOKENS=2400
MEMORY_WINDOW_MIN_TURNS=2
MEMORY_WINDOW_MAX_TURNS=12
MEMORY_WINDOW_MESSAGE_MAX_TOKENS=900
MEMORY_WINDOW_FETCH_LIMIT=96

# Conversation memory: rolling summary compression (high/low water marks).
MEMORY_SUMMARY_TRIGGER_TOKENS=3200
MEMORY_SUMMARY_RETAIN_TOKENS=1400
MEMORY_SUMMARY_MAX_TOKENS=700

# Conversation memory: long-term recall scoring and budgets.
MEMORY_RECALL_LIMIT=5
MEMORY_RECALL_CANDIDATE_LIMIT=24
MEMORY_RECALL_MIN_SIMILARITY=0.55
MEMORY_RECALL_SIMILARITY_WEIGHT=0.60
MEMORY_RECALL_RECENCY_WEIGHT=0.20
MEMORY_RECALL_CONFIDENCE_WEIGHT=0.20
MEMORY_RECALL_RECENCY_HALF_LIFE_DAYS=14
MEMORY_RECALL_MAX_TOKENS=600
MEMORY_RECALL_FALLBACK_LIMIT=3

# Conversation memory: extraction and consolidation.
MEMORY_EXTRACTION_MIN_NEW_TOKENS=120
MEMORY_EXTRACTION_MAX_MESSAGES=40
MEMORY_EXTRACTION_MIN_CONFIDENCE=0.5
MEMORY_DEDUP_SIMILARITY_THRESHOLD=0.90
MEMORY_UPDATE_SIMILARITY_THRESHOLD=0.78
MEMORY_MAX_ACTIVE_PER_USER=400

# Conversation memory: LLM (empty falls back to NOTES_PROVIDER and its models).
MEMORY_LLM_PROVIDER=
MEMORY_GEMINI_MODEL=
MEMORY_OPENAI_MODEL=
MEMORY_REQUEST_TIMEOUT_SECONDS=60
MEMORY_REQUEST_MAX_ATTEMPTS=3
MEMORY_RETRY_BACKOFF_SECONDS=2

# Conversation memory: maintenance execution.
MEMORY_MAINTENANCE_INLINE=false
MEMORY_MAINTENANCE_STALE_AFTER_MINUTES=10
MEMORY_MAINTENANCE_FETCH_LIMIT=200

# Study generation and grading. Empty provider/model values inherit AI Notes settings.
STUDY_LLM_PROVIDER=
STUDY_GEMINI_MODEL=
STUDY_OPENAI_MODEL=
STUDY_REQUEST_TIMEOUT_SECONDS=120
STUDY_REQUEST_MAX_ATTEMPTS=3
STUDY_RETRY_BACKOFF_SECONDS=2
STUDY_STALE_TASK_AFTER_MINUTES=10
STUDY_GLOBAL_MAX_CONCURRENT_REQUESTS=6
STUDY_MAX_OUTPUT_TOKENS=4096
STUDY_LEASE_SECONDS=1800
FLASHCARDS_MAX_CONCURRENT_REQUESTS=3
FLASHCARDS_GROUP_TARGET_TOKENS=2400
FLASHCARDS_GROUP_MAX_TOKENS=3600
FLASHCARDS_MAX_PER_DOCUMENT=300
FLASHCARDS_MIN_CONFIDENCE=0.5
FLASHCARDS_DEDUP_SIMILARITY_THRESHOLD=0.86
FLASHCARDS_PER_1000_SOURCE_TOKENS=3.0
QUIZ_MAX_CONCURRENT_REQUESTS=3
QUIZ_GROUP_TARGET_TOKENS=2600
QUIZ_GROUP_MAX_TOKENS=3800
QUIZ_MAX_QUESTIONS_PER_DOCUMENT=120
QUIZ_DEFAULT_DIFFICULTY_MIX=EASY:0.3,MEDIUM:0.5,HARD:0.2
QUIZ_MIN_CONFIDENCE=0.5
QUIZ_DEDUP_SIMILARITY_THRESHOLD=0.86
QUIZ_QUESTIONS_PER_1000_SOURCE_TOKENS=1.5
QUIZ_GRADING_MAX_CONCURRENT_REQUESTS=3
SRS_INITIAL_EASE=2.5
SRS_MIN_EASE=1.3
SRS_FIRST_INTERVAL_DAYS=1
SRS_SECOND_INTERVAL_DAYS=6
